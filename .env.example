# =============================================================================
# BrowseLater env vars
# Copy to .env.local for local dev. Set the same vars in Vercel for production.
# =============================================================================

# --- Supabase ----------------------------------------------------------------
# From: Supabase Project → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- Anthropic (Claude) ------------------------------------------------------
# From: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# Models (override if needed)
ANTHROPIC_MODEL_HAIKU=claude-haiku-4-5-20251001
ANTHROPIC_MODEL_SONNET=claude-sonnet-4-6
# Embeddings: Anthropic doesn't provide embeddings, we use Voyage AI by default.
# If you want a different embedding provider, swap in lib/ai/embeddings.ts.
VOYAGE_API_KEY=

# --- App ---------------------------------------------------------------------
# Public origin (used for bookmarklet, email links). No trailing slash.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Bookmarklet shared secret — long random string. Used to sign per-user tokens.
BOOKMARKLET_SIGNING_SECRET=replace-with-32-byte-random-hex

# Worker route shared secret — authenticates internal job dispatch (app → /api/worker/*).
# Generate with: openssl rand -hex 32
WORKER_SECRET=replace-with-64-char-random-hex

# --- Optional ----------------------------------------------------------------
# Set to "1" to enable verbose pipeline logs in dev.
DEBUG_PIPELINE=
